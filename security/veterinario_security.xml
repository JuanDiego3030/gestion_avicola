<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="avicola_veterinario_rule" model="ir.rule">
        <field name="name">Acceso Veterinario Propio</field>
        <field name="model_id" ref="model_avicola_veterinario"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_veterinario'))]"/>
    </record>

    <record id="avicola_veterinario_admin_rule" model="ir.rule">
        <field name="name">Acceso Completo Veterinario Administrador</field>
        <field name="model_id" ref="model_avicola_veterinario"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_veterinario_manager'))]"/>
    </record>

    <record id="avicola_plan_vacunacion_rule" model="ir.rule">
        <field name="name">Acceso Planificación por Veterinario</field>
        <field name="model_id" ref="model_avicola_plan_vacunacion"/>
        <field name="domain_force">[('veterinario_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_veterinario'))]"/>
    </record>

    <record id="avicola_plan_vacunacion_admin_rule" model="ir.rule">
        <field name="name">Acceso Completo a Planificaciones</field>
        <field name="model_id" ref="model_avicola_plan_vacunacion"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_veterinario_manager'))]"/>
    </record>
</odoo>
