            <form string="Salida a Matadero">
                <header>
                    <button name="action_confirmar" string="Confirmar" type="object"
                            class="btn-primary" invisible="estado == 'confirmado'"/>
                    <button name="action_borrador" string="Volver a Borrador" type="object"
