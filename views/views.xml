    <!-- ======== GRANJA ======== -->
    <record id="view_avicola_granja_list" model="ir.ui.view">
        <field name="name">avicola.granja.list</field>
        <field name="model">avicola.granja</field>
        <field name="arch" type="xml">
            <list string="Granjas">
                <field name="name"/>
                <field name="tipo"/>
                <field name="ubicacion"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_granja_form" model="ir.ui.view">
        <field name="name">avicola.granja.form</field>
        <field name="model">avicola.granja</field>
        <field name="arch" type="xml">
            <form string="Granja">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tipo"/>
                        <field name="ubicacion"/>
                    </group>
                    <notebook>
                        <page string="Galpones">
                            <field name="galpon_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="metros_cuadrados"/>
                                    <field name="capacidad_maxima"/>
                                    <field name="cantidad_actual"/>
                                    <field name="densidad_actual"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_granja" model="ir.actions.act_window">
        <field name="name">Granjas</field>
        <field name="res_model">avicola.granja</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======== GALPON ======== -->
    <record id="view_avicola_galpon_list" model="ir.ui.view">
        <field name="name">avicola.galpon.list</field>
        <field name="model">avicola.galpon</field>
        <field name="arch" type="xml">
            <list string="Galpones">
                <field name="granja_id"/>
                <field name="name"/>
                <field name="metros_cuadrados"/>
                <field name="capacidad_maxima"/>
                <field name="cantidad_actual"/>
                <field name="densidad_actual"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_galpon_form" model="ir.ui.view">
        <field name="name">avicola.galpon.form</field>
        <field name="model">avicola.galpon</field>
        <field name="arch" type="xml">
            <form string="Galpón">
                <sheet>
                    <group>
                        <field name="granja_id"/>
                        <field name="name"/>
                        <field name="metros_cuadrados"/>
                        <field name="capacidad_maxima"/>
                        <field name="cantidad_actual"/>
                        <field name="densidad_actual" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_galpon" model="ir.actions.act_window">
        <field name="name">Galpones</field>
        <field name="res_model">avicola.galpon</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======== DISTRIBUCION ======== -->
    <record id="view_avicola_distribucion_list" model="ir.ui.view">
        <field name="name">avicola.distribucion.list</field>
        <field name="model">avicola.distribucion</field>
        <field name="arch" type="xml">
            <list string="Distribuciones" decoration-success="estado == 'confirmado'" decoration-muted="estado == 'borrador'">
                <field name="lote_incubadora"/>
                <field name="fecha"/>
                <field name="granja_id"/>
                <field name="galpon_id"/>
                <field name="cantidad"/>
                <field name="estado" widget="badge" decoration-success="estado == 'confirmado'" decoration-warning="estado == 'borrador'"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_distribucion_form" model="ir.ui.view">
        <field name="name">avicola.distribucion.form</field>
        <field name="model">avicola.distribucion</field>
        <field name="arch" type="xml">
            <form string="Distribución de Pollitos">
                <header>
                    <button name="action_confirmar" string="Confirmar" type="object"
                            class="btn-primary" invisible="estado == 'confirmado'"/>
                    <button name="action_borrador" string="Volver a Borrador" type="object"
                            invisible="estado == 'borrador'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmado"/>
                </header>
                <sheet>
                    <group>
                        <field name="lote_incubadora"/>
                        <field name="fecha"/>
                        <field name="granja_id"/>
                        <field name="galpon_id" domain="[('granja_id', '=', granja_id)]"/>
                        <field name="cantidad"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_distribucion" model="ir.actions.act_window">
        <field name="name">Distribución de Pollitos</field>
        <field name="res_model">avicola.distribucion</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_avicola_mortalidad_list" model="ir.ui.view">
        <field name="name">avicola.mortalidad.list</field>
        <field name="model">avicola.mortalidad</field>
        <field name="arch" type="xml">
            <list string="Mortalidad de Aves" decoration-success="estado == 'confirmado'" decoration-muted="estado == 'borrador'">
                <field name="lote_incubadora"/>
                <field name="fecha"/>
                <field name="granja_id"/>
                <field name="galpon_id"/>
                <field name="cantidad"/>
                <field name="estado" widget="badge" decoration-success="estado == 'confirmado'" decoration-warning="estado == 'borrador'"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_mortalidad_form" model="ir.ui.view">
        <field name="name">avicola.mortalidad.form</field>
        <field name="model">avicola.mortalidad</field>
        <field name="arch" type="xml">
            <form string="Registro de Mortalidad">
                <header>
                    <button name="action_confirmar" string="Confirmar" type="object" class="btn-primary" invisible="estado == 'confirmado'"/>
                    <button name="action_borrador" string="Volver a Borrador" type="object" invisible="estado == 'borrador'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmado"/>
                </header>
                <sheet>
                    <group>
                        <field name="lote_incubadora" readonly="1"/>
                        <field name="fecha"/>
                        <field name="granja_id"/>
                        <field name="galpon_id" domain="[('granja_id', '=', granja_id), ('cantidad_actual', '>', 0)]"/>
                        <field name="cantidad"/>
                        <field name="observaciones"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_mortalidad" model="ir.actions.act_window">
        <field name="name">Mortalidad de Aves</field>
        <field name="res_model">avicola.mortalidad</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_avicola_veterinario_list" model="ir.ui.view">
        <field name="name">avicola.veterinario.list</field>
        <field name="model">avicola.veterinario</field>
        <field name="arch" type="xml">
            <list string="Veterinarios">
