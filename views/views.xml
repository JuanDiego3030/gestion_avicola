                    <script type="text/javascript"><![CDATA[
                    (function () {
                        window.avicolaDashboardInlineLoaded = true;
                        console.log('Dashboard inline script running');
                        function loadChartJs(callback) {
                            console.log('Dashboard loadChartJs start');
                            if (window.Chart) { console.log('Chart.js already loaded'); callback(); return; }
                            function trySourceFetch(src, onSuccess, onFail) {
                                fetch(src, { credentials: 'same-origin' }).then(function (resp) {
                                    if (!resp.ok) { throw new Error('HTTP ' + resp.status); }
                                    return resp.text();
                                }).then(function (text) {
                                    var t = (text || '').trim();
                                    if (t.indexOf('<') === 0) { throw new Error('Response appears to be HTML, not JS'); }
                                    try { (0, eval)(text); onSuccess(); } catch (e) { onFail(e); }
                                }).catch(function (err) { onFail(err); });
                            }
                            trySourceFetch('https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js', function () { callback(); }, function () {
                                trySourceFetch('/web/content/gestion_avicola/static/src/lib/chart.min.js', function () { callback(); }, function () {
                                    console.error('No se pudo cargar Chart.js');
                                });
                            });
                        }

                        // existing inline code continues (omitted for brevity)
                        loadChartJs(function () {
                            // placeholder callback to ensure Chart.js is attempted
                        });
                    })();
                    ]]></script>
                    <!-- Inline AMD module moved from static/src/js/dashboard.js -->
                    <script type="text/javascript"><![CDATA[
                    odoo.define('gestion_avicola.dashboard', ['web.rpc', 'web.core'], function (rpc, core) {
    "use strict";

    console.log('gestion_avicola.dashboard: script loaded');

    function loadChartJs_module(callback) {
        if (window.Chart) { callback(); return; }
        var cdns = [
            'https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js',
            'https://unpkg.com/chart.js@3.9.1/dist/chart.min.js'
        ];
        var attempt = 0;
        function tryLoad() {
            if (window.Chart) { callback(); return; }
            if (attempt >= cdns.length) { console.error('No se pudo cargar Chart.js desde los CDNs:', cdns); return; }
            var s = document.createElement('script');
            s.src = cdns[attempt];
            s.onload = function () { callback(); };
            s.onerror = function () { attempt += 1; tryLoad(); };
            document.head.appendChild(s);
        }
        tryLoad();
    }

    function renderCharts() {
        // Prevent double-rendering using an internal flag instead of relying
        // on `avicolaDashboardInlineLoaded` which is set elsewhere.
        if (window._avicolaDashboardRendered) { return; }
        var ctxA = document.getElementById('chart_galpones');
        if (!ctxA) { setTimeout(renderCharts, 500); return; }

        rpc.query({ model: 'avicola.galpon', method: 'search_read', args: [[], ['name', 'cantidad_actual', 'metros_cuadrados']] })
        .then(function (data) {
            var labels = data.map(function (d) { return d.name; });
            var counts = data.map(function (d) { return d.cantidad_actual || 0; });
            var densities = data.map(function (d) { return (d.metros_cuadrados && d.metros_cuadrados > 0) ? (d.cantidad_actual / d.metros_cuadrados) : 0; });

            loadChartJs_module(function () {
                try {
                    if (ctxA) {
                        new Chart(ctxA.getContext('2d'), { type: 'bar', data: { labels: labels, datasets: [{ label: 'Aves por Galpón', data: counts, backgroundColor: '#722f77' }] }, options: { responsive: true, maintainAspectRatio: false } });
                    }
                    var ctxB = document.getElementById('chart_densidades');
                    if (ctxB) { new Chart(ctxB.getContext('2d'), { type: 'line', data: { labels: labels, datasets: [{ label: 'Densidad (aves/m²)', data: densities, borderColor: '#e9b3f0', backgroundColor: 'rgba(233,179,240,0.15)', tension: 0.3 }] }, options: { responsive: true, maintainAspectRatio: false } }); }
                    var ctxC = document.getElementById('chart_pie');
                    if (ctxC) { var palette = ['#5c2261', '#722f77', '#e9b3f0', '#dcb3e3', '#bca0bf']; new Chart(ctxC.getContext('2d'), { type: 'pie', data: { labels: labels, datasets: [{ data: counts, backgroundColor: labels.map(function (_, i) { return palette[i % palette.length]; }) }] }, options: { responsive: true, maintainAspectRatio: false } }); }
                    // Mark as rendered so subsequent DOM updates don't re-create charts
                    window._avicolaDashboardRendered = true;
                } catch (e) { console.error('Error rendering charts', e); }
            });
        }).catch(function (err) { console.error('RPC error fetching galpones', err); });
    }

    core.bus.on('DOM_updated', null, renderCharts);
    setTimeout(renderCharts, 400);
});
                    ]]></script>
