                        <field name="granja_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_veterinario" model="ir.actions.act_window">
        <field name="name">Veterinarios</field>
        <field name="res_model">avicola.veterinario</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_avicola_plan_vacunacion_list" model="ir.ui.view">
        <field name="name">avicola.plan.vacunacion.list</field>
        <field name="model">avicola.plan.vacunacion</field>
        <field name="arch" type="xml">
            <list string="Planificaciones de Vacunación">
                <field name="name"/>
                <field name="veterinario_id"/>
                <field name="granja_id"/>
                <field name="fecha_planificada"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_plan_vacunacion_form" model="ir.ui.view">
        <field name="name">avicola.plan.vacunacion.form</field>
        <field name="model">avicola.plan.vacunacion</field>
        <field name="arch" type="xml">
            <form string="Planificación de Vacunación">
                <header>
                    <button name="action_programar" string="Programar" type="object" class="btn-primary"
                            invisible="state != 'borrador'"/>
                    <button name="action_realizar" string="Marcar Realizado" type="object" class="btn-success"
                            invisible="state == 'realizado'"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,programado,realizado"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="veterinario_id"/>
                        <field name="granja_id"/>
                        <field name="fecha_planificada"/>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_plan_vacunacion" model="ir.actions.act_window">
        <field name="name">Planificaciones de Vacunación</field>
        <field name="res_model">avicola.plan.vacunacion</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======== SALIDA ======== -->
