        <field name="name">avicola.salida.list</field>
        <field name="model">avicola.salida</field>
        <field name="arch" type="xml">
            <list string="Salidas a Matadero" decoration-success="estado == 'confirmado'" decoration-muted="estado == 'borrador'">
                <field name="fecha"/>
                <field name="granja_id"/>
                <field name="galpon_id"/>
                <field name="cantidad"/>
