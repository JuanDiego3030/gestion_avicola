                    <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmado"/>
                </header>
                <sheet>
                    <group>
                        <field name="fecha"/>
                        <field name="granja_id"/>
                        <field name="galpon_id" domain="[('granja_id', '=', granja_id)]"/>
