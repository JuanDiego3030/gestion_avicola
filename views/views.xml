    <!-- La acción original de Salidas apunta ahora a Despachos (los despachos reemplazan a las salidas) -->
    <record id="action_avicola_salida" model="ir.actions.act_window">
        <field name="name">Salidas a Matadero</field>
        <field name="res_model">avicola.despacho</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Esta vista muestra los despachos que reemplazan las salidas a matadero.</p>
        </field>
    </record>

    <!-- ======== DESPACHO AVES VIVAS ======== -->
    <record id="view_avicola_despacho_list" model="ir.ui.view">
        <field name="name">avicola.despacho.list</field>
        <field name="model">avicola.despacho</field>
        <field name="arch" type="xml">
            <list string="Despachos Aves Vivas">
                <field name="fecha"/>
                <field name="granja"/>
                <field name="cliente"/>
                <field name="cantidad_aves"/>
                <field name="peso_neto"/>
            </list>
        </field>
    </record>

    <record id="view_avicola_despacho_form" model="ir.ui.view">
        <field name="name">avicola.despacho.form</field>
        <field name="model">avicola.despacho</field>
        <field name="arch" type="xml">
            <form string="Despacho Aves Vivas">
                <sheet>
                    <group>
                        <label for="company_name" string="DATOS FIJOS"/>
                        <field name="company_name" readonly="1"/>
                        <field name="company_rif" readonly="1"/>
                        <field name="company_direccion" readonly="1"/>
                    </group>
                    <group>
                        <field name="fecha"/>
                        <field name="granja"/>
                        <field name="cliente"/>
                        <field name="placa"/>
                        <field name="chofer"/>
                    </group>
                    <group>
                        <field name="cant_jaulas"/>
                        <field name="pollos_por_jaula"/>
                        <field name="orden_compra"/>
                        <field name="inicio_carga"/>
                        <field name="final_carga"/>
                    </group>
                    <group>
                        <field name="cuadrilla"/>
                        <field name="cantidad_aves"/>
                        <field name="peso_neto"/>
                        <field name="peso_promedio" readonly="1"/>
                        <field name="pollo_mojado"/>
                    </group>
                    <group>
                        <field name="precinto_1"/>
                        <field name="precinto_2"/>
                        <field name="precinto"/>
                        <field name="supervisor"/>
                    </group>
                    <footer>
                        <button string="Imprimir Ticket" name="action_print_ticket" type="object" class="btn-primary"/>
                        <button string="Cerrar" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_avicola_despacho" model="ir.actions.act_window">
        <field name="name">Despachos Aves Vivas</field>
        <field name="res_model">avicola.despacho</field>
        <field name="view_mode">list,form</field>
    </record>

    

    

    

    <menuitem id="menu_avicola_despacho" name="Despachos"
              parent="menu_avicola_root" action="action_avicola_despacho" sequence="25"
              groups="gestion_avicola.group_veterinario,gestion_avicola.group_veterinario_manager,base.group_system"/>

    <!-- ======== DASHBOARD MEJORADO ======== -->
    <record id="view_avicola_dashboard_form" model="ir.ui.view">
        <field name="name">avicola.dashboard.form</field>
        <field name="model">avicola.dashboard</field>
        <field name="arch" type="xml">
            <form string="Panel de Control Avícola" class="avicola-dashboard-view" create="false" edit="false" delete="false">
                <sheet style="max-width: 100% !important; width: 100% !important; background-color: #1a1924 !important; color: #ffffff; min-height: 100vh; padding: 24px; margin: 0 !important;">
                    
                    <!-- Truco CSS Inyectado para romper el contenedor blanco de Odoo y añadir efectos de transición -->
                    <style>
                        .avicola-dashboard-view .o_form_sheet_bg { background-color: #1a1924 !important; background: #1a1924 !important; padding: 0 !important; }
                        .avicola-dashboard-view .o_form_sheet { border: none !important; box-shadow: none !important; max-width: 100% !important; background-color: #1a1924 !important; }
                        .avicola-dashboard-view .o_form_view { background-color: #1a1924 !important; }
                        .avicola-kpi-card { transition: all 0.25s ease-in-out; border: 1px solid #432447 !important; cursor: pointer; }
                        .avicola-kpi-card:hover { transform: translateY(-4px); box-shadow: 0 8px 16px rgba(0,0,0,0.5) !important; filter: brightness(1.15); }
                        .avicola-btn-filter { border: 1px solid #58245c !important; color: #e2ccde !important; font-weight: 500; transition: all 0.2s; }
                        .avicola-btn-filter:hover { background-color: #431b47 !important; color: #fff !important; }
                        .avicola-btn-active { background-color: #722f77 !important; color: #ffffff !important; box-shadow: 0 0 10px rgba(114,47,119,0.5); }
                    </style>

                    <!-- Cabecera de Filtros -->
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 2px solid #282636;">
                        <h2 style="color: #ffffff; font-weight: 700; margin: 0; letter-spacing: 0.5px;">Panel de Control General</h2>
                        <div class="btn-group" role="group" style="border-radius: 8px; overflow: hidden;">
                            <a role="button" data-range="today" class="btn avicola-btn-filter avicola-btn-active" style="padding: 8px 20px;">Hoy</a>
                            <a role="button" data-range="week" class="btn avicola-btn-filter" style="padding: 8px 20px;">Esta Semana</a>
                            <a role="button" data-range="month" class="btn avicola-btn-filter" style="padding: 8px 20px;">Este Mes</a>
                            <a role="button" data-range="all" class="btn avicola-btn-filter" style="padding: 8px 20px;">Hasta Ahora</a>
                        </div>
                    </div>

                    <!-- Grid de Tarjetas (KPIs) -->
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        
                        <!-- Tarjeta 1: Granjas -->
                        <div class="col">
                            <div class="card h-100 text-center text-white avicola-kpi-card" style="background-color: #5c2261; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.25);">
                                <div class="card-body d-flex flex-column justify-content-between p-4">
